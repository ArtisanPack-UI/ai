{
  "openapi": "3.1.0",
  "info": {
    "title": "ArtisanPack UI AI Admin API",
    "description": "REST/JSON endpoints backing the React and Vue admin surfaces for the artisanpack-ui/ai package. All endpoints require authentication (Sanctum by default) and the `manage_ai_settings` ability.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/artisanpack-ai",
      "description": "Default mount point (configurable via artisanpack.ai.api.prefix)"
    }
  ],
  "components": {
    "securitySchemes": {
      "sanctum": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Sanctum token"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        },
        "required": ["message"]
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "required": ["message", "errors"]
      },
      "CredentialsPublic": {
        "type": "object",
        "description": "Safe read-side view of the credential store. The plaintext API key is never returned.",
        "properties": {
          "provider": { "type": ["string", "null"] },
          "default_model": { "type": ["string", "null"] },
          "base_url": { "type": ["string", "null"] },
          "api_key_present": { "type": "boolean" }
        },
        "required": ["api_key_present"]
      },
      "FeatureOverride": {
        "type": "object",
        "properties": {
          "feature_key": { "type": "string" },
          "package": { "type": "string" },
          "model": { "type": ["string", "null"] },
          "instructions": { "type": ["string", "null"] }
        },
        "required": ["feature_key"]
      },
      "Feature": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "package": { "type": "string" },
          "label": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] },
          "enabled": { "type": "boolean" }
        },
        "required": ["key", "package", "enabled"]
      },
      "UsageBucket": {
        "type": "object",
        "properties": {
          "bucket": { "type": "string" },
          "input_tokens": { "type": "integer" },
          "output_tokens": { "type": "integer" },
          "cost_usd": { "type": "number" },
          "events": { "type": "integer" }
        },
        "required": ["bucket", "input_tokens", "output_tokens", "cost_usd", "events"]
      },
      "UsageFeatureRow": {
        "type": "object",
        "properties": {
          "feature_key": { "type": "string" },
          "input_tokens": { "type": "integer" },
          "output_tokens": { "type": "integer" },
          "cost_usd": { "type": "number" },
          "events": { "type": "integer" }
        },
        "required": ["feature_key", "input_tokens", "output_tokens", "cost_usd", "events"]
      },
      "UsageTotals": {
        "type": "object",
        "properties": {
          "input_tokens": { "type": "integer" },
          "output_tokens": { "type": "integer" },
          "cost_usd": { "type": "number" },
          "events": { "type": "integer" }
        },
        "required": ["input_tokens", "output_tokens", "cost_usd", "events"]
      },
      "ConnectionTestResult": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string",
            "enum": ["ok", "unsupported", "missing_key", "missing_base_url", "error"]
          },
          "message": { "type": "string" }
        },
        "required": ["result", "message"]
      }
    }
  },
  "security": [{ "sanctum": [] }],
  "paths": {
    "/settings": {
      "get": {
        "summary": "Read current credential + per-feature settings",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "credentials": { "$ref": "#/components/schemas/CredentialsPublic" },
                    "feature_overrides": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/FeatureOverride" }
                    }
                  },
                  "required": ["credentials", "feature_overrides"]
                }
              }
            }
          },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "summary": "Update credentials and per-feature overrides",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "provider": { "type": "string" },
                  "api_key": { "type": ["string", "null"], "description": "Omit or send null to keep the currently stored key." },
                  "base_url": { "type": ["string", "null"] },
                  "default_model": { "type": ["string", "null"] },
                  "feature_overrides": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/FeatureOverride" }
                  }
                },
                "required": ["provider"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" },
          "422": { "description": "Validation failed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ValidationError" } } } }
        }
      }
    },
    "/features": {
      "get": {
        "summary": "List every registered AI feature",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "features": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Feature" }
                    }
                  },
                  "required": ["features"]
                }
              }
            }
          }
        }
      }
    },
    "/features/{featureKey}/toggle": {
      "post": {
        "summary": "Enable or disable a single feature",
        "parameters": [
          {
            "name": "featureKey",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "null"], "description": "Omit to flip the current state." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Toggled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "feature": {
                      "type": "object",
                      "properties": {
                        "key": { "type": "string" },
                        "package": { "type": "string" },
                        "enabled": { "type": "boolean" }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": { "description": "Feature not registered" }
        }
      }
    },
    "/usage": {
      "get": {
        "summary": "Return usage totals + per-feature + daily buckets",
        "parameters": [
          { "name": "from", "in": "query", "required": false, "schema": { "type": "string", "format": "date" } },
          { "name": "to", "in": "query", "required": false, "schema": { "type": "string", "format": "date" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "range": {
                      "type": "object",
                      "properties": {
                        "from": { "type": "string", "format": "date-time" },
                        "to": { "type": "string", "format": "date-time" }
                      }
                    },
                    "totals": { "$ref": "#/components/schemas/UsageTotals" },
                    "by_feature": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/UsageFeatureRow" }
                    },
                    "daily": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/UsageBucket" }
                    }
                  }
                }
              }
            }
          },
          "422": { "description": "Malformed date param", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ValidationError" } } } }
        }
      }
    },
    "/test-connection": {
      "post": {
        "summary": "Probe the configured provider without saving",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "provider": { "type": "string" },
                  "api_key": { "type": ["string", "null"] },
                  "base_url": { "type": ["string", "null"] },
                  "default_model": { "type": ["string", "null"] }
                },
                "required": ["provider"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Provider reachable",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConnectionTestResult" }
              }
            }
          },
          "422": {
            "description": "Provider unreachable / missing config / probe error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConnectionTestResult" }
              }
            }
          }
        }
      }
    }
  }
}
